# ─────────────────────────────────────────
# ELDOX v3 — Variáveis de Ambiente
# Copie para .env e preencha os valores reais
# NUNCA commite o .env com valores reais
# ─────────────────────────────────────────

# Banco de Dados (PostgreSQL 16)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/eldox?schema=public"

# Redis (cache + filas BullMQ)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="troque-por-string-aleatoria-longa-em-producao"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# MinIO (storage S3-compatible)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="seu-access-key"
MINIO_SECRET_KEY="seu-secret-key"
MINIO_BUCKET="eldox-files"

# Servidor
PORT=3000
NODE_ENV="development"
# Em produção: NODE_ENV="production" — ativa logs em arquivo (logs/app.log)
