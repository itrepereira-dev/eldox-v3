# PostgreSQL
POSTGRES_DB=eldox
POSTGRES_USER=seu_usuario_aqui
POSTGRES_PASSWORD=sua_senha_aqui

# MinIO
MINIO_ROOT_USER=seu_minio_user_aqui
MINIO_ROOT_PASSWORD=sua_minio_senha_aqui
