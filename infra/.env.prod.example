# Domínio
DOMAIN=v3.eldox.com.br
GITHUB_REPO=itrepereira-dev/eldox-v3

# Banco de dados
POSTGRES_DB=eldox_v3
POSTGRES_USER=eldox_v3
POSTGRES_PASSWORD=TROCAR_SENHA_FORTE

# JWT
JWT_SECRET=TROCAR_SECRET_FORTE_64_CHARS
JWT_REFRESH_SECRET=TROCAR_REFRESH_SECRET_FORTE_64_CHARS
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# MinIO (S3 compatível)
MINIO_ENDPOINT=minio.eldox.com.br
MINIO_PORT=443
MINIO_ACCESS_KEY=TROCAR
MINIO_SECRET_KEY=TROCAR
MINIO_BUCKET=eldox-ged
MINIO_USE_SSL=true

# API URL para o frontend (build time)
VITE_API_URL=https://v3.eldox.com.br/api/v1
